# ============================================================
# Forever Remembered — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (Email)
RESEND_API_KEY=re_...
EMAIL_FROM=hello@foreverremembered.ai

# App
NEXT_PUBLIC_URL=https://foreverremembered.ai

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ============================================================
# Phase 2 — Stripe Payments
# ============================================================

# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (create products in Stripe Dashboard first)
# Keep — $39 one-time payment
STRIPE_PRICE_KEEP=price_...
# Cherish — $127 one-time payment
STRIPE_PRICE_CHERISH=price_...
# Legacy — $397 one-time payment
STRIPE_PRICE_LEGACY=price_...

# ============================================================
# Phase 3 — Fulfillment Pipeline
# ============================================================

# Admin secret for manual fulfillment retry endpoint
# Generate a random string: openssl rand -hex 32
ADMIN_SECRET=your-secret-here
